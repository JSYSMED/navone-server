# NavOne Server 환경변수 (실제 값은 Vercel에 설정)

# Supabase (lib/supabase.js)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Telegram 봇 (lib/telegram.js)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI GPT-4o-mini (api/cs-reply.js, api/claim/* 클레임 분류)
OPENAI_API_KEY=

# 커머스 API 자격증명(client_id/client_secret)은 환경변수가 아니라
# Supabase stores 테이블에 저장되며 lib/commerce-auth.js 가 licenseKey로 조회.
